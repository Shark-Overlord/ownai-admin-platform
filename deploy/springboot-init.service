[Unit]
Description=Spring Boot Init
After=network.target mysqld.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/springboot-init
EnvironmentFile=/etc/springboot-init/springboot-init.env
ExecStart=/usr/bin/java -jar /opt/springboot-init/app.jar
SuccessExitStatus=143
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
